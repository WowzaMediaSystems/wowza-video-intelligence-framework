<Root>
	<Transcode>
		<Description></Description>
		<Decode>
			<Video>
				<Implementation>NVCUVID_EVA</Implementation>
				<Deinterlace>false</Deinterlace>
				<EnableDynamicOverlays>true</EnableDynamicOverlays>				
			</Video>
		</Decode>
		<Scale>
			<Implementation>CUDA_EVA</Implementation>
		</Scale>
		<Encodes>
			<Encode>
				<!-- Need at least one encode to get frames -->
				<Name>videoIntelligence</Name>
				<Enable>true</Enable>
				<Description></Description>
				<StreamName>mp4:${SourceStreamName}-vi</StreamName>
				<Video>
					<Codec>H.264</Codec>
					<Implementation>NVENC_EVA</Implementation>
					<GPUID>-1</GPUID>
					<Profile>baseline</Profile>
					<Bitrate>1500000</Bitrate>
					<KeyFrameInterval>
						<FollowSource>false</FollowSource>
						<Interval>30</Interval>
					</KeyFrameInterval>
                    <!-- Use letterbox, fit-width, fit-height, crop, stretch, or match-source. The default is fit-height. -->	
					<FrameSize> <!-- VIF Module will set the FitMode, Width and Height as needed -->
						<FitMode>fit-height</FitMode>
						<Width>0</Width>
						<Height>0</Height>
						<Crop>0,0,0,0</Crop>
						<SourceRectangle></SourceRectangle>
					</FrameSize>
				</Video>
				<Audio>
					<Codec>Disable</Codec>
					<Bitrate>0</Bitrate>
				</Audio>
			</Encode>
			<Encode>
				<Name>360p</Name>
				<Enable>false</Enable>
				<Description></Description>
				<StreamName>mp4:${SourceStreamName}_360p</StreamName>
				<Video>
					<Codec>H.264</Codec>
					<Implementation>NVENC</Implementation>
					<GPUID>-1</GPUID>
					<Profile>baseline</Profile>
					<Bitrate>1500000</Bitrate>
					<KeyFrameInterval>
						<FollowSource>false</FollowSource>
						<Interval>30</Interval>
					</KeyFrameInterval>
                    <!-- Use letterbox, fit-width, fit-height, crop, stretch, or match-source. The default is fit-height. -->	
					<FrameSize>
						<FitMode>fit-height</FitMode>
						<Width>0</Width>
						<Height>360</Height>
						<Crop>0,0,0,0</Crop>
						<SourceRectangle></SourceRectangle>
					</FrameSize>
				</Video>
				<Audio>
					<Codec>AAC</Codec>
					<Bitrate>96000</Bitrate>>
				</Audio>
			</Encode>			
		</Encodes>
	</Transcode>
</Root>